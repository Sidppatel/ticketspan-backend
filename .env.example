# TicketSpan Event Backend — environment template. Copy to `.env` and fill in.
# Loaded by startup.ps1, which runs the API with --no-launch-profile so
# launchSettings.json is ignored (local startup == production). Every key maps
# to a configuration[...] lookup in src/Api — no others are read by the code.


# ─── Runtime / hosting ───────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:60262
GRPC_HTTP2_ONLY=false


# ─── Database (connection string composed from these by Db.cs) ───────────────
DB_HOST=127.0.0.1
DB_PORT=5432
# Runtime uses least-privilege ep_app so RLS tenant isolation is enforced
# (superuser/owner roles bypass RLS). Migrations/seed run as ep_dev.
DB_USER=ep_app
DB_NAME=event_platform
DB_PASSWORD=ep_app_password
# Privileged role for startup seeding/migrations (bypasses RLS). Defaults to ep_dev.
DB_BOOTSTRAP_USER=ep_dev
DB_BOOTSTRAP_PASSWORD=ep_dev_password
# Disable | Allow | Prefer | Require | VerifyCA | VerifyFull
DATABASE_SSL_MODE=Disable


# ─── CORS (exact-origin match, no wildcards) ─────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://admin.localhost:5173,http://staff.localhost:5173,http://developer.localhost:5173
# Prod apex whose subdomains are all allowed (e.g. ticketspan.com). *.localhost always allowed in dev.
CORS_BASE_DOMAIN=


# ─── JWT signing (JWT_SIGNING_KEY must be 32+ bytes) ─────────────────────────
JWT_SIGNING_KEY=
JWT_ISSUER=ticketspan
JWT_AUDIENCE=ticketspan-clients
JWT_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_MINUTES=43200


# ─── Password hashing (peppers + current version) ────────────────────────────
PASSWORD_PEPPER_V1=
PASSWORD_PEPPER_CURRENT=1


# ─── Google sign-in (public client ID also mirrored to frontend) ─────────────
GOOGLE_CLIENT_ID=
# Confidential — server-only. For the OAuth authorization-code exchange.
GOOGLE_CLIENT_SECRET=


# ─── Stripe (secret + webhook server-only; publishable mirrored to frontend) ─
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=


# ─── Public base URL ─────────────────────────────────────────────────────────
# Backend origin (asset URLs + Stripe onboarding redirect target).
PUBLIC_BASE_URL=http://localhost:60262
# Admin frontend origin Stripe onboarding return/refresh bounces to.
FRONTEND_ADMIN_URL=http://admin.localhost:5173


# ─── Email ───────────────────────────────────────────────────────────────────
# Local dev: writes .html files here instead of sending (leave RESEND_API_KEY blank).
LOCAL_EMAIL_DIR=
# Deployed: set RESEND_API_KEY to send via Resend. When set, LOCAL_EMAIL_DIR is ignored.
RESEND_API_KEY=


# ─── Image storage (blank S3_BUCKET → local disk under LOCAL_UPLOAD_ROOT) ─────
LOCAL_UPLOAD_ROOT=
S3_BUCKET=
S3_SERVICE_URL=

